# Copy this file to .env and set real values.

# Required: long random string, at least 32 characters.
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Optional: Gemini API key for AI calorie/body/exercise features.
# Keep this only on the backend. Do not expose it as VITE_GEMINI_KEY.
GEMINI_KEY=

# Admin email used by the frontend/admin endpoints.
ADMIN_EMAIL=vid.oreskovic@gmail.com

# SQLite path. Defaults to powergraph.db in this folder.
# DB_PATH=powergraph.db

# API port. Defaults to 3001.
# PORT=3001

# Frontend origin allowed by CORS. Use the exact deployed origin in production.
# CORS_ORIGIN=http://localhost:5173
