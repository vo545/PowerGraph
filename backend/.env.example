# Copy this file to .env and set real values locally.
# Never commit real secrets.

PORT=3001
JWT_SECRET=replace_with_a_long_random_secret_only_in_local_env
JWT_EXPIRES_IN=30d
AUTH_MAX_ATTEMPTS=8
DATABASE_URL=./powergraph.db

# Optional backend-only AI key.
GEMINI_KEY=replace_with_backend_only_gemini_key_if_used
GEMINI_MODEL=gemini-1.5-flash

# Optional app/admin configuration.
ADMIN_EMAIL=admin@example.com
CORS_ORIGIN=http://localhost:5173

# Optional Gmail/SMTP password reset. Use a Gmail App Password, not your real Gmail password.
APP_NAME=PowerGraph
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=PowerGraph <your_gmail@gmail.com>
