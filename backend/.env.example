# Kopiraj to datoteko v .env in nastavi vrednosti

# OBVEZNO: dolg naključen niz (vsaj 32 znakov)
JWT_SECRET=zamenjaj-z-dolgim-nakljucnim-nizom-vsaj-32-znakov

# Gemini API ključ (za ocenjevalec kalorij)
GEMINI_KEY=

# Email admina
ADMIN_EMAIL=vid.oreskovic@gmail.com

# Pot do SQLite baze (privzeto: powergraph.db v isti mapi)
# DB_PATH=powergraph.db

# Port (privzeto: 3001)
# PORT=3001

# Dovoljeni CORS origin (privzeto: * — vse)
# CORS_ORIGIN=http://localhost:5173
